{
	"compilerOptions": {
		"baseUrl": ".",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"moduleDetection": "force",
		"target": "es2022",
		"lib": ["ES2022"],
		"paths": {
			"@sphido/*": ["packages/*/lib"]
		},
		"declaration": true,
		"declarationMap": true,
		"skipLibCheck": true,
		"outDir": "./dist"
	}
}
